# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockdb
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# Redis
REDIS_URL=redis://localhost:6379/1

# Dify Cloud API Key（至 cloud.dify.ai 取得）
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret（建議使用 openssl rand -hex 32 產生）
JWT_SECRET=your-random-secret-here
# CORS — 生產環境改為實際 domain
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# DigiRunner（本地開發用）
DIGIRUNNER_SERVICE_URL=http://quantdashboardai-digirunner-1:18080
DIGIRUNNER_USERNAME=manager
DIGIRUNNER_PASSWORD=your-password-here

# FinMind Token（選填，提高 API 限額；至 finmindtrade.com 免費註冊取得）
# 不填仍可使用，但每日請求次數較少
FINMIND_TOKEN=xxx

# Cloud Scheduler Token（上 GCP 後設定，本地可留空）
# Cloud Scheduler 呼叫時在 Header 加入：X-Scheduler-Token: 此值
SCHEDULER_SECRET=your-scheduler-secret-here
