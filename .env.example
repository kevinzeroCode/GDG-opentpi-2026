# ======================================
# QuantDashboard AI - 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ======================================

# Dify 工作流程 API（透過 DigiRunner Gateway）
# 啟動 DigiRunner 後，路由設定請參考 digirunner/README.md
VITE_DIFY_API_URL=http://localhost:31080/dify/v1

# Dify API 金鑰（在 Dify 後台 → API 頁面取得）
VITE_DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
