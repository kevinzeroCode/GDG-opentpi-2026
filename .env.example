# ======================================
# QuantDashboard AI - 環境變數範本
# ======================================
#
# 【重要】生產環境部署方式：
#   不需要 .env 檔案，直接在伺服器 shell 設定：
#   export DIFY_API_KEY=app-xxxxxxxxxxxx
#   docker compose up -d
#
# 【本地開發】才需要 .env：
#   複製此檔案為 .env 並填入實際值
#   .env 已在 .gitignore 中，請勿 commit

# Dify API（本地開發用，生產環境由 nginx 代理，此變數不需要）
VITE_DIFY_API_URL=https://api.dify.ai/v1
VITE_DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# EmailJS 警報通知（至 https://www.emailjs.com 免費註冊取得）
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxx

# Firebase（至 Firebase Console 取得）
VITE_FIREBASE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
